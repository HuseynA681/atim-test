    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "groq-sdk": "^1.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.11.0",
    "openai": "^6.42.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
